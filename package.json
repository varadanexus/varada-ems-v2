  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "check:pwa": "node scripts/check-pwa.cjs",
    "check:android": "node scripts/check-android.cjs",
    "check:migrations": "node scripts/check-supabase-migrations.cjs",
    "db:status": "cd new-ems && supabase migration list --linked",
    "db:dry-run": "npm run check:migrations && cd new-ems && supabase db push --linked --dry-run",
    "db:push": "npm run check:migrations && cd new-ems && supabase db push --linked",
    "site:serve": "npx serve . -p 5501",
    "android:web": "node scripts/build-android-web.cjs",
    "android:sync": "npm run android:web && cap sync android",
    "android:open": "npm run android:sync && cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug"
  },
