# Generated CLI / debug session logs — never commit these.
# No log file in this repository is intentionally versioned; all known instances
# (Supabase CLI session output, db push runs, local static server output) were
# generated artifacts removed from history during the 2026-06-30 repository cleanup.
/bootstrap-debug.log
/interiors-commercial-reset.log
/interiors-commercial-start.log
/interiors-commercial-workflow-reset.log
/prod-db-push.log
/prod-db-push-include-all.log
/static-server.log

# General generated-artifact patterns (CLI output, process logs, traces, dumps).
*.log
*.out
*.trace
*.dump

# Supabase CLI connection/cache state is machine-local.
**/supabase/.temp/

# MCP server (Claude Desktop blog admin) — deps & secrets are machine-local.
/mcp/node_modules/
/mcp/.env
/node_modules/

# Capacitor copies this deterministic web bundle into the native project.
/native-www/
/android/app/src/main/assets/public/
/android/.gradle/
/android/local.properties
/android/app/build/
/android/app/google-services.json
/signing/
