# Varada blog-admin MCP — environment template.
# Copy the values into your Claude Desktop config (see docs/MCP_SETUP.md).
# NEVER commit real keys. The service-role key is server-side only.

# --- Required ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BLOG_ADMIN_SECRET=any-long-random-string-you-choose
SITE_URL=https://varadanexus.com

# --- AI providers (at least one required for generate/refresh/backfill content) ---
# Router tries them in the order set in ai_router_settings.provider_priority.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LinkedIn (optional — only needed to publish_linkedin_post) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:organization:00000000

# --- Optional ---
BLOG_ADMIN_ACTOR=claude-desktop
